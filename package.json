{
  "name": "reverse-proxy-extension",
  "displayName": "Reverse Proxy",
  "description": "Start and stop an SSH reverse proxy from VS Code.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onCommand:reverseProxy.showStatus",
    "onCommand:reverseProxy.showLogs",
    "onCommand:reverseProxy.openSettings",
    "onView:reverseProxy.sidebarView",
    "onCommand:reverseProxy.openKeyProjectSettings",
    "onCommand:reverseProxy.refreshKeyProjects"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reverseProxy.showStatus",
        "title": "Reverse Proxy: Show Status"
      },
      {
        "command": "reverseProxy.showLogs",
        "title": "Reverse Proxy: Show Logs"
      },
      {
        "command": "reverseProxy.openSettings",
        "title": "Reverse Proxy: Settings"
      },
      {
        "command": "reverseProxy.refreshKeyProjects",
        "title": "ToolBox: Refresh Key Projects"
      },
      {
        "command": "reverseProxy.openKeyProjectSettings",
        "title": "ToolBox: Key Projects Settings"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reverseProxy",
          "title": "ToolBox",
          "icon": "media/proxy.svg"
        }
      ]
    },
    "views": {
      "reverseProxy": [
        {
          "id": "reverseProxy.sidebarView",
          "name": "ToolBox",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Reverse Proxy",
      "properties": {
        "reverseProxy.configFile": {
          "type": "string",
          "default": "reverse-proxy.config.json",
          "description": "Path to reverse proxy config JSON file. Relative path resolves from workspace root."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "compile-tests": "tsc -p ./tsconfig.test.json",
    "pretest": "npm run compile && npm run compile-tests",
    "test": "node ./out/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.1",
    "mocha": "^10.7.3",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "bootstrap-icons": "^1.13.1"
  }
}
